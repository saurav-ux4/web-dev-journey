import {useEffect,useState} from "react";
import TodoForm from "./component/TodoForm";
import TodoList from "./component/TodoList";
import { getTodos,
         createTodo,
         deleteTodo,
         updateTodo
        } from "./services/api";


function App() {

   //==============STATES=================
 const [todos, setTodos] = useState([]);

 const [loading, setLoading] =
    useState(true);

 const [error, setError] =
    useState("");     

//========== FETCH TODOS ==========

  const fetchTodos = async () => {
    try {
      setLoading(true);

      const response = await getTodos();

      setTodos(response.data);

      setError("");
    } catch (error) {
      console.log(error);

      setError("Failed to fetch todos");
    } finally {
      setLoading(false);
    }
  };

// ========= RUN ON PAGE LOAD =========

  useEffect(() => {
    fetchTodos();
  }, []);


//================ADD TODO================
   const handleAddTodo = async (text) => {
  try {
    const response = await createTodo({
      text
    });

    setTodos((prevTodos) => [
      ...prevTodos,
      response.data
    ]);
  } catch (error) {
    console.log(error);
  }
};


//==================DELETE TODO===========
const handleDeleteTodo = async (id) => {
  try {
    await deleteTodo(id);

    setTodos((prevTodos) =>
      prevTodos.filter(
        (todo) => todo._id !== id
      )
    );
  } catch (error) {
    console.log(error);
  }
};


//=================toggle======================
const handleToggleTodo = async (todo) => {
  try{

    const updatedTodo = {
      ...todo,
      completed: !todo.completed
    };

    const savedTodo = await updateTodo(
      todo._id,
      updatedTodo
    );

    setTodos(
      todos.map((t) =>
        t._id === todo._id
          ? savedTodo
          : t
      )
    );

  }catch(error){
    console.log(error);
  }
};

//==============LOADING UI=============
  if (loading) {
    return <h1>Loading...</h1>;
    
  }


//==============MAIN UI================
  return (

 <div className="app">
     <div className="todo-container">
    <h1>todo app</h1>
      
       {error && <p>{error}</p>}

      <TodoForm onAdd={handleAddTodo}/>

      <TodoList  todos={todos}
                 onDelete={handleDeleteTodo}
                 onToggle={handleToggleTodo}
                />

     </div>
 </div>
  );
}

export default App;
</file>

